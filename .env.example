# ============================================
# Algolia 搜索配置（模板）
# ============================================
# 复制此文件为 .env，然后填入你的真实密钥：
#   cp .env.example .env
#
# 获取方式：
# 1. 注册 Algolia https://www.algolia.com/
# 2. 进入 Dashboard → API Keys
# 3. 复制 Application ID 和 Search-Only API Key
# 4. 进入 Data → Indices 创建索引，复制索引名称
#
# ⚠️ VITE_ALGOLIA_API_KEY   = Search-Only API Key（只能搜索，暴露在前端安全）
# ⚠️ ALGOLIA_ADMIN_API_KEY  = Admin API Key（可读写，只在本地脚本用，绝对不要提交！）

VITE_ALGOLIA_APP_ID=your_app_id_here
VITE_ALGOLIA_API_KEY=your_search_only_api_key_here
VITE_ALGOLIA_INDEX_NAME=your_index_name_here
ALGOLIA_ADMIN_API_KEY=your_admin_api_key_here
